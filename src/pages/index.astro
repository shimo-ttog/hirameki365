---
import '../styles/design-tokens.css';
import { getCollection } from 'astro:content';
import pkg from '../../package.json';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

// 全てのMarkdown記事を取得
const blogEntries = await getCollection('blog');

// 記事を日付でマッピング
const postsMap = {};
blogEntries.forEach((entry) => {
  postsMap[entry.data.date] = entry;
});

// 現在のシステム日付を取得
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
const todayStr = `${year}-${String(month).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;

// 1日の曜日を取得 (0:日, 1:月, ..., 5:金, 6:土)
const firstDayOfMonth = new Date(year, month - 1, 1).getDay();
const daysInMonth = new Date(year, month, 0).getDate();

// カレンダー表示用の配列作成
const calendarDays = [];
// 月初の空白
for (let i = 0; i < firstDayOfMonth; i++) {
  calendarDays.push(null);
}
// 日付を入れる
for (let j = 1; j <= daysInMonth; j++) {
  calendarDays.push(j);
}

const weekdays = ['日', '月', '火', '水', '木', '金', '土'];

// バージョン情報を取得
const version = pkg.version;
---
<html lang="ja">
  <head>
    <GoogleAnalytics />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ひらめき365｜大人の脳活</title>
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="theme-color" content="#1B2C4E" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body>
    <!-- 文字サイズ設定 -->
    <div class="top-controls no-print">
      {import.meta.env.DEV && (
        <div class="test-controls" style="margin-right: auto; padding-left: 1rem;">
          <button id="test-clear-all" class="font-btn" style="background-color: #ffeef0; color: #e74c3c; border-color: #e74c3c;">⚠️ 全データを消去</button>
        </div>
      )}
      <div class="font-size-controls">
        <span>文字サイズ：</span>
        <button class="font-btn active" data-size="normal">標準</button>
        <button class="font-btn" data-size="large">大</button>
        <button class="font-btn" data-size="xlarge">特大</button>
      </div>
    </div>

    <header>
      <h1>ひらめき365</h1>
      <p class="subtitle">大人の脳活・記憶力トレーニング</p>
      <div class="current-month">{year}年{month}月</div>
    </header>

    <main>
      <div class="calendar-grid">
        {weekdays.map((wd) => (
          <div class={`weekday-header ${wd === '日' ? 'sun' : wd === '土' ? 'sat' : ''}`}>
            {wd}
          </div>
        ))}

        {calendarDays.map((day) => {
          if (day === null) return <div class="calendar-day empty"></div>;

          const dateStr = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
          const post = postsMap[dateStr];
          const isToday = dateStr === todayStr;
          const isFuture = new Date(dateStr) > now;

          return (
            <div class={`calendar-day ${isToday ? 'today' : ''} ${!post ? 'no-content' : ''}`} data-date={post ? post.id : dateStr}>
              {post ? (
                <a href={`/blog/${post.id}`} class="day-link">
                  <span class="day-number">{day}</span>
                  <span class="day-label">✏️</span>
                </a>
              ) : (
                <div class="day-disabled">
                  <span class="day-number">{day}</span>
                </div>
              )}
            </div>
          );

        })}
      </div>
    </main>

    <footer>
      <p>© 2026 ひらめき365 事務局 <span class="version">v0.7.4</span></p>
    </footer>

    <script>
      // 文字サイズ変更の制御
      const fontBtns = document.querySelectorAll('.font-btn');
      function applyFontSize(size) {
        document.body.classList.remove('font-large', 'font-xlarge');
        if (size === 'large') document.body.classList.add('font-large');
        if (size === 'xlarge') document.body.classList.add('font-xlarge');
        fontBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.size === size));
        localStorage.setItem('hirameki365-fontsize', size);
      }

      const savedSize = localStorage.getItem('hirameki365-fontsize') || 'normal';
      applyFontSize(savedSize);
      fontBtns.forEach(btn => btn.addEventListener('click', () => applyFontSize(btn.dataset.size)));

      // 全データ消去機能（テスト用）
      document.getElementById('test-clear-all')?.addEventListener('click', () => {
        if (confirm('すべての回答記録を消去して初期状態に戻しますか？')) {
          localStorage.removeItem('hirameki365-results');
          window.location.reload();
        }
      });

      // Service Workerの登録
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').then(reg => {
            // 新しいSWが見つかった時の処理
            reg.addEventListener('updatefound', () => {
              const newWorker = reg.installing;
              newWorker?.addEventListener('statechange', () => {
                if (newWorker.state === 'activated') {
                  // 新しいバージョンが有効になったらリロードを促すか自動リロード
                  console.log('New version available, reloading...');
                  window.location.reload();
                }
              });
            });
          }).catch(err => {
            console.log('SW registration failed:', err);
          });
        });

        // SWが更新されたらページを自動リロードする
        let refreshing = false;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (!refreshing) {
            window.location.reload();
            refreshing = true;
          }
        });
      }

      // localStorageから結果を読み取ってカレンダーに反映
      function syncCalendar() {
        const resultsRaw = localStorage.getItem('hirameki365-results');
        const results = JSON.parse(resultsRaw || '{}');
        
        // 日本時間 (JST) での「今日」を取得
        const nowJST = new Date(new Date().toLocaleString("en-US", {timeZone: "Asia/Tokyo"}));
        const y = nowJST.getFullYear();
        const m = String(nowJST.getMonth() + 1).padStart(2, '0');
        const d = String(nowJST.getDate()).padStart(2, '0');
        const todayStr = `${y}-${m}-${d}`;

        console.group(`Calendar Sync (v0.7.4) - Today: ${todayStr}`);
        
        // 全ての日付要素を取得してループ
        const days = document.querySelectorAll('.calendar-day[data-date]');

        days.forEach((dayEl) => {
          const dateAttr = dayEl.dataset.date;
          const data = results[dateAttr];
          const label = dayEl.querySelector('.day-label');
          const link = dayEl.querySelector('.day-link');
          
          // .md を除去して比較
          const cleanDate = dateAttr.replace('.md', '');
          const isToday = cleanDate === todayStr;
          const isFuture = cleanDate > todayStr;

          console.log(`Checking ${dateAttr}: isToday=${isToday}, isFuture=${isFuture}`);

          // 状態のリセット
          dayEl.classList.remove('today', 'future', 'status-playing', 'status-passed', 'status-tried');
          if (isToday) dayEl.classList.add('today');
          
          if (isFuture) {
            dayEl.classList.add('future');
            if (link) {
              link.removeAttribute('href');
              link.style.cursor = 'default';
            }
            if (label) {
              label.style.display = 'none'; // 未来日は鉛筆を消して中央寄せを維持
            }
          }

          if (label && !isFuture) {
            label.classList.remove('is-completed');
            label.textContent = '✏️';
            label.style.fontSize = '';
            label.style.color = '';
            label.style.display = 'block';
          }

          if (!data || isFuture) return;

          // ステータスの解析
          let status = '';
          let score = 0;
          if (typeof data === 'string') {
            status = data;
            score = (status === 'passed' ? 7 : 0);
          } else {
            status = data.status || '';
            score = data.score || 0;
          }

          if (status) {
            dayEl.classList.add(`status-${status}`);
            if (label) {
              if (status === 'playing') {
                label.textContent = '回答中';
                label.style.fontSize = '0.8rem';
                label.style.color = 'var(--color-accent-gold)';
              } else if (status === 'passed' || status === 'tried') {
                let resultText = `${score}/7`;
                if (status === 'passed') resultText += ' 💮';
                label.textContent = resultText;
                label.classList.add('is-completed');
                
                if (link) link.setAttribute('title', '結果を見る');
              }
            }
          }
        });
        console.groupEnd();
      }

      // 初回実行と、戻るボタン（bfcache）対策
      document.addEventListener('DOMContentLoaded', syncCalendar);
      window.addEventListener('pageshow', (event) => {
        console.log('[EVENT] pageshow', { persisted: event.persisted });
        syncCalendar();
      });

      // 他のタブでの変更を検知
      window.addEventListener('storage', (event) => {
        if (event.key === 'hirameki365-results') {
          console.log('[STORAGE] 外部での変更を検知しました。再同期します。');
          syncCalendar();
        }
      });
    </script>
  </body>
</html>

  <style>
  body { padding: 1.5rem; max-width: 800px; margin: 0 auto; background-color: var(--color-bg-ivory); }
  
  /* 画面上部の設定コントロール */
  .top-controls {
    display: flex; justify-content: flex-end; margin-bottom: 1rem;
  }
  .font-size-controls {
    display: flex; align-items: center; gap: 0.5rem; font-weight: bold; color: var(--color-primary-navy);
  }
  .font-btn {
    padding: 0.4rem 0.8rem; border: 2px solid var(--color-primary-navy);
    background: white; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 0.9rem;
    transition: all 0.2s;
  }
  .font-btn.active { background: var(--color-primary-navy); color: white; }

  /* 文字サイズ変更用クラス (顕著な変化) */
  body.font-large { font-size: 22px !important; }
  body.font-xlarge { font-size: 28px !important; }

  /* 要素ごとの調整 */
  body.font-large h1 { font-size: 3rem; }
  body.font-xlarge h1 { font-size: 3.5rem; }
  body.font-large .calendar-day { min-height: 80px; }
  body.font-xlarge .calendar-day { min-height: 100px; }

  header { text-align: center; margin-bottom: 2rem; }
  h1 { color: var(--color-primary-navy); font-size: 2.5rem; margin-bottom: 0.2rem; }
  .subtitle { color: var(--color-primary-green); font-weight: bold; font-size: 1.1rem; margin-bottom: 1rem; }
  .current-month { 
    display: inline-block; padding: 0.5rem 2rem; background-color: var(--color-primary-navy); 
    color: white; border-radius: 50px; font-weight: bold; font-size: 1.2rem;
  }

  .calendar-grid { 
    display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 8px; 
    background: white; padding: 12px; border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 2px solid var(--color-border);
    width: 100%; box-sizing: border-box;
  }

  .weekday-header { 
    text-align: center; font-weight: bold; padding: 12px 0; border-bottom: 2px solid var(--color-border);
    font-size: 1.1rem; min-width: 0;
  }
  .weekday-header.sun { color: var(--color-stamp-red); }
  .weekday-header.sat { color: #2D4A9E; }

  .calendar-day { 
    aspect-ratio: 1 / 1; min-height: 60px; display: flex; flex-direction: column; 
    border-radius: 8px; border: 1px solid var(--color-border); position: relative;
    overflow: hidden; box-sizing: border-box;
  }

  .day-link, .day-disabled {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    text-decoration: none; color: var(--color-primary-navy); transition: background 0.2s;
    position: relative;
  }
  .day-link { background: white; }
  .day-link:hover { background-color: #FFFDF0; }
  
  .day-number { font-size: 1.4rem; font-weight: bold; line-height: 1; z-index: 1; }
  
  /* 絵文字ラベルのスタイル - 絶対配置で数字の中央寄せに影響を与えない */
  .day-label { 
    position: absolute; bottom: 4px; left: 0; right: 0; text-align: center;
    font-size: 1rem; z-index: 1; transition: all 0.3s; 
  }
  .day-label.is-completed { 
    font-size: 0.75rem;
    font-weight: bold;
    color: var(--color-primary-navy);
  }

  .calendar-day.today { border: 3px solid var(--color-accent-gold); background-color: #FFF9E6; }
  .calendar-day.today::after {
    content: "今日"; position: absolute; top: 2px; right: 2px; 
    font-size: 0.6rem; background: var(--color-accent-gold); color: white;
    padding: 1px 4px; border-radius: 4px; z-index: 2;
  }

  .calendar-day.future {
    opacity: 0.7;
    background-color: #F9F9F9;
  }

  /* 進行中（回答途中）のスタイル */
  .calendar-day.status-playing {
    background-color: #fffde6;
    border: 2px dashed var(--color-accent-gold);
  }

  /* 完了済み（回答済み）のスタイル */
  .calendar-day.status-passed, .calendar-day.status-tried {
    background-color: #f5f5f5;
  }
  .calendar-day.status-passed .day-link:hover, 
  .calendar-day.status-tried .day-link:hover {
    background-color: #eee;
  }

  .day-disabled {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    color: #CCC; background: #F5F5F5; cursor: not-allowed;
  }

  .empty { border: none; background: transparent; }

  footer { text-align: center; margin-top: 3rem; color: #666; font-size: 0.9rem; }

  @media (max-width: 600px) {
    body { padding: 0.4rem; overflow-x: hidden; }
    header h1 { font-size: 1.5rem; }
    .subtitle { font-size: 0.8rem; }
    .calendar-grid { 
      width: 100%; 
      padding: 2px; 
      gap: 2px; /* 隙間をさらに詰める */
      box-sizing: border-box;
      margin: 0;
    }
    .weekday-header { font-size: 0.75rem; padding: 4px 0; }
    .calendar-day { 
      min-height: 40px; 
      border-radius: 4px;
    }
    .day-number { font-size: 0.9rem; }
    .day-label { font-size: 0.6rem; } /* スマホでも表示されるように修正 */
    .day-label.is-completed { font-size: 0.5rem; margin-top: 2px; }
    .calendar-day.today { border-width: 2px; }
    .calendar-day.today::after { 
      font-size: 0.4rem; 
      padding: 0 1px; 
      top: 0px; 
      right: 0px;
      border-radius: 2px;
    }
  }
</style>
