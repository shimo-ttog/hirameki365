---
import '../../styles/design-tokens.css';
import { getCollection, render } from 'astro:content';
import pkg from '../../../package.json';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// バージョン情報を取得
const version = pkg.version;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title}</title>
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="theme-color" content="#1B2C4E" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body>
    <div class="top-controls no-print">
      <button id="menu-toggle" class="control-btn menu-btn">⚙️ 設定</button>
      <div id="controls-panel" class="controls-content">
        <div class="sound-control">
          <button id="sound-toggle" class="control-btn" title="音声を切り替える">🔊 音あり</button>
        </div>
        <div class="font-size-controls">
          <span>文字サイズ：</span>
          <button class="font-btn active" data-size="normal">標準</button>
          <button class="font-btn" data-size="large">大</button>
          <button class="font-btn" data-size="xlarge">特大</button>
        </div>
        {import.meta.env.DEV && (
          <div class="test-controls" style="margin-left: 1.5rem; padding-left: 1.5rem; border-left: 1px solid #ccc;">
            <button id="test-reset-btn" class="control-btn" style="background-color: #ffeef0; border-color: #e74c3c; color: #e74c3c;">🔄 進捗リセット</button>
          </div>
        )}
      </div>
    </div>

    <article>
      <header class="quiz-header">
        <a href="/" class="site-logo">ひらめき365</a>
        <h1 class="quiz-date">{entry.data.title.replace('ひらめき365：', '')}</h1>
      </header>
      
      <div class="brain-content">
        <Content />
      </div>

      <!-- 最終結果ステップをAstro側で定義（Markdownのパースエラー回避） -->
      <div class="quiz-step" data-step="final" style="display: none;">
        <div id="already-answered-placeholder"></div>
        <div class="final-summary">
          <h2>お疲れ様でした！</h2>
          <p id="final-score-text"></p>
          <div id="final-stamp-container" class="stamp-wrapper hidden">
            <div class="stamp-success">合格</div>
          </div>
          
          <div id="share-section" class="share-area hidden">
            <p style="font-size: 1.1rem; margin-bottom: 0.8rem; font-weight: bold;">結果を報告する：</p>
            <div class="share-btns">
              <a id="share-line" target="_blank" rel="noopener noreferrer" class="share-btn line">LINEで送る</a>
              <a id="share-x" target="_blank" rel="noopener noreferrer" class="share-btn x">Xでつぶやく</a>
            </div>
          </div>
        </div>

        <hr>

        <div class="final-extra-content" style="width: 100%; text-align: center;">
          <h3>【今日の豆知識】</h3>
          <p>{entry.data.trivia}</p>

          <hr>
          
          <div class="maxim-section">
            <h3>📜 今日の格言</h3>
            <p class="maxim-text">{entry.data.maxim}</p>
          </div>
        </div>
        
        <div class="step-nav" style="margin-top: 3rem;">
          <button onclick="window.location.href='/'" class="btn-adult btn-primary">カレンダーに戻る</button>
        </div>
      </div>

      <div class="print-footer only-print">
        <p>ひらめき365：大人の脳活・記憶力トレーニング</p>
      </div>

      <footer class="no-print" style="text-align: center; margin-top: 3rem; color: #666; font-size: 0.8rem;">
        <p>© 2026 ひらめき365 事務局 v0.7.0</p>
      </footer>
    </article>

    <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script define:vars={{ slug: entry.id }}>
      // 起動時にサーバーから渡されたslugを使用
      console.log(`[INIT] Quiz Page for: ${slug} (v0.7.0)`);

      // Service Workerの登録
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(err => {
            console.log('SW registration failed:', err);
          });
        });
      }

      let currentStep = 1;
      const totalSteps = 7;
      let score = 0;

      // 効果音の設定 (フリー音源を使用)
      const sounds = {
        correct: new Audio('/sounds/correct.mp3'),
        incorrect: new Audio('/sounds/incorrect.mp3'),
        perfect: new Audio('/sounds/perfect.mp3')
      };
      
      let isMuted = localStorage.getItem('hirameki365-muted') === 'true';
      const soundToggle = document.getElementById('sound-toggle');

      function updateSoundUI() {
        if (soundToggle) {
          soundToggle.textContent = isMuted ? '🔇 消音中' : '🔊 音あり';
          soundToggle.classList.toggle('muted', isMuted);
        }
      }

      function playSound(type) {
        if (!isMuted && sounds[type]) {
          sounds[type].currentTime = 0;
          sounds[type].play().catch(e => console.log('Audio play blocked:', e));
        }
      }

      soundToggle?.addEventListener('click', () => {
        isMuted = !isMuted;
        localStorage.setItem('hirameki365-muted', isMuted);
        updateSoundUI();
      });

      updateSoundUI();

      /**
       * 表記ゆれを吸収するための正規化関数
       */
      function normalize(str) {
        if (!str) return '';
        const normalized = str
          .trim()
          .replace(/[Ａ-Ｚａ-ｚ０-９]/g, (s) => String.fromCharCode(s.charCodeAt(0) - 0xfee0))
          .replace(/[\u30a1-\u30f6]/g, (s) => String.fromCharCode(s.charCodeAt(0) - 0x60))
          .replace(/[円￥\\,，]/g, '')
          .replace(/曜日?/g, '')
          .replace(/[\s　]/g, '')
          .toLowerCase();
        return normalized;
      }

      function showStep(step) {
        document.querySelectorAll('.quiz-step').forEach(el => el.style.display = 'none');
        const stepEl = document.querySelector(`.quiz-step[data-step="${step}"]`);
        if (stepEl) {
          stepEl.style.display = 'block';
          window.scrollTo(0, 0);
          
          const input = stepEl.querySelector('.user-answer-input');
          if (input) {
            input.focus();
          }

          bindSpeechButtons(stepEl);
        }
      }

      function bindSpeechButtons(container) {
        container.querySelectorAll('.question-block').forEach((block) => {
          if (block.querySelector('.speech-btn')) return;
          
          let text = block.querySelector('.question-text')?.textContent;
          if (!text) return;

          const sectionTitle = block.closest('.quiz-step').querySelector('h3')?.textContent;
          let isKanjiQ = sectionTitle === '難読漢字';
          if (isKanjiQ) {
            text = text.replace(/「(.+?)」/g, (match, p1) => {
              return '「' + '○'.repeat(p1.length).split('').join('、') + '」';
            });
          }

          const btn = document.createElement('button');
          btn.className = 'speech-btn';
          btn.innerHTML = '🔊';
          btn.onclick = () => speak(text, btn);
          block.appendChild(btn);
        });
      }

      function speak(text, btn) {
        if (window.speechSynthesis.speaking) {
          window.speechSynthesis.cancel();
          if (btn.classList.contains('speaking')) {
            btn.classList.remove('speaking');
            return;
          }
        }
        document.querySelectorAll('.speech-btn').forEach(b => b.classList.remove('speaking'));
        const uttr = new SpeechSynthesisUtterance(text);
        uttr.lang = 'ja-JP';
        uttr.rate = 0.9;
        uttr.onstart = () => btn.classList.add('speaking');
        uttr.onend = () => btn.classList.remove('speaking');
        uttr.onerror = () => btn.classList.remove('speaking');
        window.speechSynthesis.speak(uttr);
      }

      function setupEventListeners() {
        document.querySelectorAll('.user-answer-input').forEach(input => {
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              const step = input.closest('.quiz-step').dataset.step;
              const judgeBtn = document.querySelector(`.judge-btn[data-step="${step}"]`);
              if (judgeBtn) judgeBtn.click();
            }
          });
        });

        document.querySelectorAll('.judge-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const step = e.target.dataset.step;
            const block = document.querySelector(`.quiz-step[data-step="${step}"] .question-block`);
            const correct = block?.dataset.correct || '';
            const input = block?.querySelector('.user-answer-input');
            const radios = block?.querySelectorAll('.user-answer-radio');
            const mark = block?.querySelector('.judgment-mark');
            const answerHidden = block?.querySelector('.answer-hidden');
            const nextBtn = document.querySelector(`.next-btn[data-step="${step}"]`);
            
            let userAnswer = '';
            if (input) {
              userAnswer = input.value;
            } else if (radios && radios.length > 0) {
              const checked = Array.from(radios).find((r) => r.checked);
              userAnswer = checked ? checked.value : '';
            }

            const correctAnswers = correct.split('|').map((s) => normalize(s));
            const isCorrect = correctAnswers.includes(normalize(userAnswer));

            if (isCorrect) {
              score++;
              playSound('correct');
            } else {
              playSound('incorrect');
            }

            if (mark) {
              mark.textContent = isCorrect ? '⭕️ 正解！' : '❌ おしい！';
              mark.className = 'judgment-mark ' + (isCorrect ? 'correct' : 'incorrect');
            }

            if (answerHidden) answerHidden.classList.add('reveal');
            btn.style.display = 'none';
            if (nextBtn) nextBtn.classList.remove('hidden');

            saveProgress('playing', true);
          });
        });

        document.querySelectorAll('.next-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            currentStep++;
            if (currentStep <= totalSteps) {
              saveProgress('playing', false);
              showStep(currentStep);
            } else {
              showFinalResult();
            }
          });
        });
      }

      function showFinalResult(silent = false) {
        showStep('final');
        const scoreText = document.getElementById('final-score-text');
        const stampContainer = document.getElementById('final-stamp-container');
        
        // 全問正解数を再集計
        let finalScore = 0;
        document.querySelectorAll('.question-block').forEach((block) => {
          const mark = block.querySelector('.judgment-mark');
          if (mark && mark.classList.contains('correct')) {
            finalScore++;
          }
        });
        
        const allCorrect = finalScore === totalSteps;

        if (scoreText) {
          let message = `全 ${totalSteps} 問中 <span style="font-size: 2rem; color: var(--color-stamp-red);">${finalScore}</span> 問正解でした！`;
          if (allCorrect) {
            message += '<br><span style="color: var(--color-stamp-red); font-weight: bold;">パーフェクト！素晴らしいです！</span>';
          } else {
            message += '<br>明日もまた挑戦して脳を活性化させましょう！';
          }
          scoreText.innerHTML = message;
        }

        if (stampContainer) {
          if (allCorrect) {
            stampContainer.classList.remove('hidden');
          } else {
            stampContainer.classList.add('hidden');
          }
        }

        if (!silent) {
          saveProgress(allCorrect ? 'passed' : 'tried', true);
        }

        // 完了済みメッセージを常に表示
        const placeholder = document.getElementById('already-answered-placeholder');
        if (placeholder) {
          const results = JSON.parse(localStorage.getItem('hirameki365-results') || '{}');
          const currentStatus = results[slug]?.status;
          
          if (silent || currentStatus === 'passed' || currentStatus === 'tried') {
            placeholder.innerHTML = `
              <div style="padding: 1.2rem; margin-bottom: 2rem; background-color: #eef7ff; border: 4px solid var(--color-primary-navy); border-radius: 16px; color: var(--color-primary-navy); font-weight: bold; font-size: 1.5rem; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                ✅ この日のトレーニングは完了しています
              </div>
            `;
          } else {
            placeholder.innerHTML = '';
          }
        }

        const shareSection = document.getElementById('share-section');
        if (shareSection) shareSection.classList.remove('hidden');

        if (!silent && allCorrect && typeof confetti === 'function') {
          playSound('perfect');
          confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 }, zIndex: 9999 });
        }
      }

      const fontBtns = document.querySelectorAll('.font-btn');
      function applyFontSize(size) {
        document.body.classList.remove('font-large', 'font-xlarge');
        if (size === 'large') document.body.classList.add('font-large');
        if (size === 'xlarge') document.body.classList.add('font-xlarge');
        fontBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.size === size));
        localStorage.setItem('hirameki365-fontsize', size);
      }

      const savedSize = localStorage.getItem('hirameki365-fontsize') || 'normal';
      applyFontSize(savedSize);
      fontBtns.forEach(btn => btn.addEventListener('click', () => applyFontSize(btn.dataset.size)));

      const menuToggle = document.getElementById('menu-toggle');
      const controlsPanel = document.getElementById('controls-panel');
      menuToggle?.addEventListener('click', () => {
        controlsPanel?.classList.toggle('open');
        menuToggle.textContent = controlsPanel?.classList.contains('open') ? '❌ 閉じる' : '⚙️ 設定';
      });

      const resetBtn = document.getElementById('test-reset-btn');
      resetBtn?.addEventListener('click', () => {
        if (confirm('回答状況をリセットして最初からやり直しますか？（テスト環境専用）')) {
          const results = JSON.parse(localStorage.getItem('hirameki365-results') || '{}');
          delete results[slug];
          localStorage.setItem('hirameki365-results', JSON.stringify(results));
          window.location.reload();
        }
      });

      function loadProgress() {
        const results = JSON.parse(localStorage.getItem('hirameki365-results') || '{}');
        const progress = results[slug];
        const status = progress?.status;
        const answers = progress?.answers || [];
        
        if (progress && (status === 'playing' || status === 'passed' || status === 'tried')) {
          currentStep = progress.currentStep || 1;
          const isJudged = progress.isJudged || false;
          
          for (let s = 1; s <= totalSteps; s++) {
             const stepEl = document.querySelector(`.quiz-step[data-step="${s}"]`);
             if (stepEl) {
               const block = stepEl.querySelector('.question-block');
               const answerHidden = block?.querySelector('.answer-hidden');
               const judgeBtn = document.querySelector(`.judge-btn[data-step="${s}"]`);
               const nextBtn = document.querySelector(`.next-btn[data-step="${s}"]`);
               const mark = block?.querySelector('.judgment-mark');
               
               const isCorrect = answers[s-1] === true;
               const isIncorrect = answers[s-1] === false;

               // 回答済みの状態を復元
               if (isCorrect || isIncorrect) {
                 if (answerHidden) answerHidden.classList.add('reveal');
                 if (judgeBtn) judgeBtn.style.display = 'none';
                 if (nextBtn) nextBtn.classList.remove('hidden');
                 if (mark) {
                   mark.textContent = isCorrect ? '⭕️ 正解！' : '❌ おしい！';
                   mark.className = 'judgment-mark ' + (isCorrect ? 'correct' : 'incorrect');
                 }
               }
             }
          }

          if (isJudged && status === 'playing') {
            if (currentStep < totalSteps) {
              currentStep++;
            } else {
              showFinalResult(true);
              return;
            }
          }

          if (status === 'passed' || status === 'tried') {
            showFinalResult(true);
            return;
          }
        }
        showStep(currentStep);
      }

      function saveProgress(status = 'playing', isJudged = false) {
        try {
          const results = JSON.parse(localStorage.getItem('hirameki365-results') || '{}');
          
          // ステータスの固定保護（一度 passed/tried になったら playing には戻さない）
          const existing = results[slug];
          const existingStatus = existing?.status;
          if ((existingStatus === 'passed' || existingStatus === 'tried') && status === 'playing') {
            console.log(`[SAVE-SKIPPED] Status is already '${existingStatus}', won't revert to 'playing'.`);
            return;
          }

          // 正誤状況の収集
          const questionResults = [];
          let currentScore = 0;
          document.querySelectorAll('.question-block').forEach((block) => {
            const mark = block.querySelector('.judgment-mark');
            if (mark?.classList.contains('correct')) {
              questionResults.push(true);
              currentScore++;
            } else if (mark?.classList.contains('incorrect')) {
              questionResults.push(false);
            } else {
              questionResults.push(null);
            }
          });

          // データを保存
          results[slug] = {
            status: status,
            score: currentScore,
            currentStep: currentStep,
            isJudged: isJudged,
            answers: questionResults,
            updatedAt: new Date().toISOString()
          };
          localStorage.setItem('hirameki365-results', JSON.stringify(results));
          console.log(`[SAVE] Key: ${slug}, Status: ${status}, Score: ${currentScore}/7`);
          console.table(results[slug]);
        } catch (e) {
          console.error('Save failed:', e);
        }
      }

      loadProgress();
      setupEventListeners();
    </script>
  </body>
</html>

<style>
body { padding: 2rem; max-width: 800px; margin: 0 auto; background: var(--color-bg-ivory); transition: font-size 0.3s ease; }

.top-controls {
  display: flex; align-items: center; justify-content: flex-end;
  gap: 1.5rem; margin-bottom: 1rem; position: relative;
}

.controls-content { display: flex; align-items: center; gap: 1.5rem; }
.menu-btn { display: none; }

.font-size-controls {
  display: flex; align-items: center;
  gap: 0.5rem; font-weight: bold; color: var(--color-primary-navy);
}

.control-btn, .font-btn {
  padding: 0.5rem 1rem; border: 2px solid var(--color-primary-navy);
  background: white; border-radius: 8px; cursor: pointer; font-weight: bold;
  transition: all 0.2s;
}

.font-btn.active { background: var(--color-primary-navy); color: white; }
.control-btn:hover { background: #f0f7ff; }

/* 文字サイズ変更用クラス (design-tokens.cssに合わせて顕著に) */
body.font-large { font-size: 22px !important; }
body.font-xlarge { font-size: 28px !important; }

/* クイズ内容（問題・入力・回答）のサイズ調整 */
body.font-large :global(.question-text) { font-size: 1.6rem; }
body.font-xlarge :global(.question-text) { font-size: 2.0rem; }

body.font-large :global(.user-answer-input) { font-size: 1.8rem; }
body.font-xlarge :global(.user-answer-input) { font-size: 2.2rem; }

body.font-large :global(.choice-label) { font-size: 1.6rem; }
body.font-xlarge :global(.choice-label) { font-size: 2.0rem; }

body.font-large :global(.answer-hidden) { font-size: 1.5rem; }
body.font-xlarge :global(.answer-hidden) { font-size: 1.8rem; }

body.font-large :global(.explanation-text) { font-size: 1.3rem; }
body.font-xlarge :global(.explanation-text) { font-size: 1.6rem; }

body.font-large h1.quiz-date { font-size: 1.8rem; }
body.font-xlarge h1.quiz-date { font-size: 2.2rem; }

article { background: white; padding: 2.5rem; border-radius: 24px; box-shadow: 0 15px 35px rgba(0,0,0,0.07); min-height: 60vh; }

/* クイズ用ヘッダースタイル */
.quiz-header { text-align: center; margin-bottom: 2rem; border-bottom: 4px solid var(--color-primary-navy); padding-bottom: 0.8rem; }
.site-logo { display: block; font-size: 1.8rem; font-weight: bold; color: var(--color-primary-navy); text-decoration: none; margin-bottom: 0.5rem; }
.site-logo:hover { opacity: 0.7; }
.quiz-date { font-size: 1.4rem; color: var(--color-text-main); margin: 0; }

:global(.quiz-step) { animation: fadeIn 0.5s ease-out; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

:global(.step-indicator) { display: inline-block; padding: 0.3rem 1rem; background: var(--color-primary-green); color: white; border-radius: 20px; font-weight: bold; font-size: 0.9rem; margin-bottom: 1rem; }
:global(.question-block) { margin-bottom: 2rem; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 16px; background: #fafafa; position: relative; }
:global(.question-text) { font-size: 1.3rem; font-weight: bold; margin-bottom: 1.5rem; padding-right: 3rem; line-height: 1.6; }

:global(.speech-btn) { position: absolute; top: 1rem; right: 1rem; background: white; border: 2px solid var(--color-primary-navy); border-radius: 50%; width: 44px; height: 44px; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 5; }
:global(.speech-btn.speaking) { background: var(--color-accent-gold); animation: pulse 1.5s infinite; }

:global(.step-nav) { display: flex; justify-content: center; gap: 1rem; margin-top: 2rem; }
:global(.hidden) { display: none !important; }

:global(.user-answer-input) { width: 100%; max-width: 400px; box-sizing: border-box; font-size: 1.5rem; padding: 0.8rem 1.2rem; border: 3px solid var(--color-primary-navy); border-radius: 12px; margin-bottom: 1rem; display: block; margin-left: auto; margin-right: auto; }
:global(.choices-group) { display: flex; flex-direction: column; gap: 0.8rem; margin-bottom: 1rem; }
:global(.choice-label) { display: block; padding: 1rem; background: white; border: 2px solid var(--color-border); border-radius: 12px; cursor: pointer; font-size: 1.3rem; }
:global(.user-answer-radio) { transform: scale(1.5); margin-right: 1rem; }

:global(.judgment-mark) { display: block; font-size: 1.8rem; font-weight: bold; margin: 1rem 0; text-align: center; }
:global(.judgment-mark.correct) { color: #2ecc71; }
:global(.judgment-mark.incorrect) { color: #e74c3c; }

:global(.answer-hidden) { margin-top: 1.5rem; padding: 1rem; background-color: #f0f0f0; border-radius: 8px; color: transparent; transition: all 0.6s ease; user-select: none; display: block; }
:global(.answer-hidden.reveal) { color: var(--color-primary-navy); background-color: #eef7ff; border-left: 5px solid var(--color-primary-navy); user-select: text; }

:global(.explanation-text) { 
  opacity: 0; 
  transition: opacity 0.6s ease;
  margin-top: 0.8rem;
  padding-top: 0.8rem;
  border-top: 1px solid rgba(27, 44, 78, 0.1);
  font-size: 1.1rem;
  line-height: 1.5;
  color: #555;
}
:global(.answer-hidden.reveal .explanation-text) { opacity: 1; }

:global(.maxim-section) { margin: 2rem 0; padding: 1.5rem; background-color: #fdfaf0; border: 2px dashed var(--color-primary-green); border-radius: 16px; text-align: center; }
:global(.maxim-text) { font-size: 1.4rem; font-weight: bold; font-style: italic; }

/* 共有エリア */
:global(.share-area) {
  margin-top: 1rem;
  padding: 1rem;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  background: #fff;
  width: 90%;
